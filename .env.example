# NanoClaw Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Anthropic/LM Studio API Configuration
# ============================================================================

# Option 1: Use LM Studio (local LLM) - Recommended for privacy
# LM Studio provides an OpenAI-compatible API at http://localhost:1234 (no /v1 suffix)
# Inside the container, use host.docker.internal to reach the host machine.
ANTHROPIC_BASE_URL=http://host.docker.internal:1234
# ANTHROPIC_AUTH_TOKEN is used instead of ANTHROPIC_API_KEY for LM Studio
# Most LM Studio instances don't require auth, but set any non-empty value if needed
# ANTHROPIC_AUTH_TOKEN=

# Optional: Specify the model to use (default: claude-sonnet-4-6)
# For Qwen models in LM Studio:
# CLAUDE_MODEL=qwen/qwen-coder-next
# CLAUDE_MODEL=qwen/qwen-2-7b
# CLAUDE_MODEL=deepseek-ai/deepseek-coder

# Option 2: Use Anthropic's cloud API (original)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Option 3: Use CLAUDE_CODE_OAUTH_TOKEN (Claude Code subscription)
# CLAUDE_CODE_OAUTH_TOKEN=claude_token_here

# ============================================================================
# LM Studio Specific (Docker)
# ============================================================================
# When using LM Studio with Docker, the container accesses host via
# host.docker.internal (built-in Docker DNS name).
# LM_STUDIO_PORT defaults to 1234 if not set.
# LM_STUDIO_PORT=1234

# ============================================================================
# Model Configuration
# ============================================================================
# CLAUDE_MODEL specifies which model the agent should use.
#
# For LM Studio with Qwen models:
#   CLAUDE_MODEL=qwen/qwen-coder-next
#   CLAUDE_MODEL=qwen/qwen-2-7b
#
# For Anthropic cloud models:
#   CLAUDE_MODEL=claude-sonnet-4-6
#   CLAUDE_MODEL=claude-opus-4-6
#
# If not set, defaults to: claude-sonnet-4-6

# ============================================================================
# Apple Container (macOS) Configuration
# ============================================================================
# For Apple Container, LM Studio is accessed via Unix socket.
# Uncomment and configure if using Apple Container instead of Docker:
#
# ANTHROPIC_BASE_URL=http://host.docker.internal:1234/v1
# (Docker Desktop also works on macOS, host.docker.internal is available)

# Added by skill
TELEGRAM_BOT_TOKEN=
TELEGRAM_ONLY=
